[Unit]
Description=Smart Project Tracker (Streamlit)
After=network.target

[Service]
Type=simple
User=tracker
WorkingDirectory=/opt/tracker
ExecStart=/opt/tracker/venv/bin/streamlit run /opt/tracker/app.py --server.port 8501 --server.headless true --server.enableCORS false
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

# Security
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/tracker

[Install]
WantedBy=multi-user.target
